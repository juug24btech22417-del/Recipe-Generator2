{
  "entities": {
    "Recipe": {
      "title": "Recipe",
      "description": "A recipe generated by the AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ingredients": { "type": "array" },
        "instructions": { "type": "array" },
        "prepTime": { "type": "string" },
        "cookTime": { "type": "string" },
        "categories": { "type": "array" },
        "nutrition": { "type": "object" },
        "note": { "type": "string" },
        "tips": { "type": "array" },
        "variations": { "type": "array" },
        "authorUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date" }
      },
      "required": ["id", "title", "ingredients", "instructions", "authorUid", "createdAt"]
    }
  },
  "firestore": {
    "/recipes/{recipeId}": {
      "schema": { "$ref": "Recipe" },
      "description": "Shared recipes"
    }
  }
}
