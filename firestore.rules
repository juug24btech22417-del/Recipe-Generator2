rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() { return request.auth != null; }
    
    match /recipes/{recipeId} {
      allow read: if true; // Publicly readable for sharing
      allow create: if isAuthenticated() && (request.resource.data.authorUid == request.auth.uid || request.resource.data.authorUid == 'anonymous');
      allow update: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || resource.data.authorUid == 'anonymous');
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || resource.data.authorUid == 'anonymous');
    }
  }
}
